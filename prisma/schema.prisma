generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// ── Auth models (NextAuth / Auth.js v5) ──────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?   // bcrypt hash; null for OAuth-only users
  role          String    @default("user")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts     Account[]
  sessions     Session[]
  playbooks    Playbook[]
  subscription UserSubscription?
  credits      UserCredit[]
}

model Account {
  id                String   @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

// ── Billing models ────────────────────────────────────────────────────────────

model UserSubscription {
  id               String    @id @default(cuid())
  userId           String    @unique
  plan             String    @default("free") // "free" | "starter" | "growth" | "professional"
  status           String    @default("active") // "active" | "cancelled" | "past_due" | "trialing"
  stripeCustomerId String?
  stripePriceId    String?
  stripeSubId      String?
  currentPeriodEnd DateTime?
  trialEnd         DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserCredit {
  id         String   @id @default(cuid())
  userId     String
  amount     Int      // positive = purchased/granted, negative = consumed
  reason     String   // "purchased" | "trial_grant" | "consumed" | "refund"
  playbookId String?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ── Playbook models ───────────────────────────────────────────────────────────

model Playbook {
  id                String    @id
  userId            String?
  productName       String
  productUrl        String?
  productBrief      String    // JSON
  targetCompany     String
  targetUrl         String?
  industry          String
  geography         String
  priorityTier      String    @default("tier1")
  status            String    @default("draft")
  progressPct       Int       @default(0)
  agentStatus       String    @default("[]") // JSON array of AgentStatus
  failedReason      String?
  completedAt       DateTime?
  openclawSessionId String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  user     User?             @relation(fields: [userId], references: [id])
  runs     PlaybookRun[]
  contacts PlaybookContact[]
  sections PlaybookSection[]
  sources  PlaybookSource[]
  events   PlaybookEvent[]
}

model PlaybookRun {
  id                String    @id @default(cuid())
  playbookId        String
  phase             String    // "research" | "writing" | "review"
  status            String    @default("queued") // "queued" | "running" | "succeeded" | "failed" | "cancelled"
  attempt           Int       @default(1)
  startedAt         DateTime?
  completedAt       DateTime?
  failedAt          DateTime?
  errorMessage      String?
  openclawSessionId String?
  processId         Int?
  stdoutPath        String?
  stderrPath        String?
  rawOutput         String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  playbook Playbook       @relation(fields: [playbookId], references: [id])
  events   PlaybookEvent[]
}

model PlaybookContact {
  id                     String   @id @default(cuid())
  playbookId             String
  name                   String
  title                  String
  company                String   @default("")
  linkedinUrl            String?
  email                  String?
  rationale              String?
  sourceUrls             String   @default("[]") // JSON
  confidence             String   @default("medium") // "high" | "medium" | "low"
  source                 String   @default("AI Research")
  verificationStatus     String   @default("pending") // "pending" | "confirmed" | "needs_review" | "removed"
  notes                  String?
  personalizationSignals String   @default("[]") // JSON
  directQuotes           String   @default("[]") // JSON
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  playbook Playbook @relation(fields: [playbookId], references: [id])
}

model PlaybookSection {
  id              String   @id @default(cuid())
  playbookId      String
  sectionKey      String   // "executive_summary" | "account_intelligence" | etc.
  title           String
  contentMarkdown String   @default("")
  status          String   @default("pending") // "pending" | "generating" | "complete" | "reviewed"
  orderIndex      Int
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  playbook Playbook        @relation(fields: [playbookId], references: [id])
  sources  PlaybookSource[]
}

model PlaybookSource {
  id                 String    @id @default(cuid())
  playbookId         String
  sectionId          String?
  url                String
  title              String?
  publisher          String?
  retrievedAt        DateTime?
  confidence         String?   // "high" | "medium" | "low"
  note               String?
  claim              String?
  verificationStatus String    @default("unverified") // "verified" | "needs_review" | "unverified"
  createdAt          DateTime  @default(now())

  playbook Playbook         @relation(fields: [playbookId], references: [id])
  section  PlaybookSection? @relation(fields: [sectionId], references: [id])
}

model PlaybookEvent {
  id         String   @id @default(cuid())
  playbookId String
  runId      String?
  type       String
  message    String
  metadata   String   @default("{}") // JSON
  createdAt  DateTime @default(now())

  playbook Playbook     @relation(fields: [playbookId], references: [id])
  run      PlaybookRun? @relation(fields: [runId], references: [id])
}
