###############################################################################
# ABMSignal — production environment template
#
# Copy to `.env.production` on the server and fill in real values:
#     cp .env.production.example .env.production
#     chmod 600 .env.production
#
# NEVER commit .env.production (it is git-ignored). Values prefixed with
# NEXT_PUBLIC_ are ALSO needed at `docker build` time (see docker-compose.yml).
###############################################################################

# ── Core ────────────────────────────────────────────────────────────────────
NODE_ENV=production
# Public base URL of the app (used for links, callbacks, emails)
NEXT_PUBLIC_APP_URL=https://app.abmsignal.com

# ── Database (libsql / SQLite) ───────────────────────────────────────────────
# Default: shared SQLite file on the `appdata` Docker volume.
DATABASE_URL=file:/data/prod.db
# For managed/multi-node libsql (Turso) instead:
# DATABASE_URL=libsql://your-db.turso.io?authToken=YOUR_TURSO_TOKEN

# ── Redis / job queue ────────────────────────────────────────────────────────
REDIS_PASSWORD=change-me-long-random-string
REDIS_URL=redis://:change-me-long-random-string@redis:6379
# Worker parallelism (number of concurrent playbook jobs per worker container)
WORKER_CONCURRENCY=3

# ── Auth.js / NextAuth v5 ────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=
AUTH_URL=https://app.abmsignal.com
AUTH_TRUST_HOST=true

# Google OAuth (Google Cloud Console → Credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Email (Resend) — magic links + transactional ────────────────────────────
RESEND_API_KEY=
EMAIL_FROM=ABMSignal <noreply@abmsignal.com>

# ── Payments (Stripe) ────────────────────────────────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Price IDs from your Stripe dashboard (live mode)
STRIPE_GROWTH_PRICE_ID=
STRIPE_STARTER_PRICE_ID=
STRIPE_PROFESSIONAL_PRICE_ID=
STRIPE_AGENCY_PRICE_ID=

# ── AI engine (external OpenClaw cluster) ────────────────────────────────────
ENGINE_RUNNER_URL=
ENGINE_RUNNER_API_KEY=
OPENCLAW_ABMSIGNAL_URL=
OPENCLAW_ABMSIGNAL_TOKEN=
AGENT_TIMEOUT_MS=1800000

# ── Supabase (optional / legacy — only if you use Supabase storage) ──────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
